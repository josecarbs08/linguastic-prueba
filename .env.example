# Lingüastic Backend - Variables de Entorno
# NUNCA subas este archivo a GitHub (agrégalo a .gitignore)

# Supabase - Usa tu SERVICE KEY aquí (nunca la ANON KEY)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...TU_SERVICE_KEY_AQUI...

# Configuración del servidor
PORT=3001
NODE_ENV=production

# CORS - Dominios permitidos (separa con comas)
ALLOWED_ORIGINS=https://linguastic.net,https://www.linguastic.net
